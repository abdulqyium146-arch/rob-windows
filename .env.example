# Rob's Window Cleaning — Environment Variables
# Copy to .env.local and fill in real values

# Production site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://robswindowcleaning.co.uk

# Google Search Console — add after verifying domain ownership
# Get from: https://search.google.com/search-console → Settings → Ownership verification → HTML tag
GOOGLE_VERIFICATION_CODE=

# Contact form endpoint — sign up at https://formspree.io
CONTACT_FORM_ENDPOINT=https://formspree.io/f/your-form-id

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
